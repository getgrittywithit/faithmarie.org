# Faith Marie Foundation Environment Variables
# Copy this file to .env.local and fill in your values
# Full setup guide: docs/EXTERNAL_SERVICES_SETUP.md

# ===================
# SUPABASE (Required)
# ===================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://znwcraymlngmymhlrfde.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===================
# STRIPE (Required for Donations)
# ===================
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use sk_test_ and pk_test_ for development, sk_live_ and pk_live_ for production
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Webhook secret - different for local (Stripe CLI) vs production
# Local: Run `stripe listen --forward-to localhost:3000/api/webhook` to get secret
# Production: Create webhook at https://dashboard.stripe.com/webhooks for /api/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ===================
# RESEND (Required for Email)
# ===================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx

# Create an audience at https://resend.com/audiences for newsletter subscribers
RESEND_AUDIENCE_ID=xxxxx

# Webhook signing secret for email tracking (opens, clicks, bounces)
# Get this when creating webhook at https://resend.com/webhooks for /api/webhooks/resend
RESEND_WEBHOOK_SECRET=whsec_xxxxx

# Email to receive notifications (new subscribers, donations, contact forms)
NOTIFICATION_EMAIL=info@faithmarie.org

# ===================
# ANTHROPIC API (Required for AI Chatbot)
# ===================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ===================
# UPSTASH REDIS (Required for Email Series)
# ===================
# Set up at: https://console.upstash.com/
# Required for 7-day grief series to track subscriber progress
KV_REST_API_URL=https://xxxxx.upstash.io
KV_REST_API_TOKEN=xxxxx

# ===================
# SITE CONFIGURATION
# ===================
# Base URL for the site (used in emails and redirects)
# Local: http://localhost:3000
# Production: https://faithmarie.org
NEXT_PUBLIC_SITE_URL=https://faithmarie.org

# Secret to protect cron endpoints from unauthorized access
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-string
