# Faith Marie Foundation Environment Variables
# Copy this file to .env.local and fill in your values

# ===================
# ANTHROPIC API (Required for AI Chatbot)
# ===================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ===================
# STRIPE (Required for Donations)
# ===================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ===================
# RESEND (Required for Email)
# ===================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx
RESEND_AUDIENCE_ID=xxxxx

# Email to receive notifications (new subscribers, donations, etc.)
NOTIFICATION_EMAIL=info@faithmarie.org

# ===================
# UPSTASH REDIS (Required for Email Series)
# ===================
# Set up at: https://console.upstash.com/
# Required for 7-day grief series to track subscribers
# Without this, subscriber data is lost on server restart
KV_REST_API_URL=https://xxxxx.upstash.io
KV_REST_API_TOKEN=xxxxx

# ===================
# CRON SECURITY (Optional but Recommended)
# ===================
# Secret to protect cron endpoints from unauthorized access
CRON_SECRET=your-random-secret-string

# ===================
# SUPABASE (Required for Admin Dashboard)
# ===================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://znwcraymlngmymhlrfde.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===================
# OPTIONAL
# ===================
# Base URL for the site (used in emails)
NEXT_PUBLIC_BASE_URL=https://faithmarie.org
